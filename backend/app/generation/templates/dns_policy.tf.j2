resource "google_dns_policy" "{{ resource.terraform_resource_name }}" {
  project                   = "{{ resource.project }}"
  name                      = "{{ resource.name }}"
  enable_inbound_forwarding = {{ attrs.enable_inbound_forwarding | lower }}
  enable_logging            = {{ attrs.enable_logging | lower }}
{% if attrs.description %}
  description               = "{{ attrs.description }}"
{% endif %}

{% for net in attrs.networks %}
  networks {
    network_url = "{{ net }}"
  }
{% endfor %}
}
