resource "aws_iam_role" "{{ resource.terraform_resource_name }}" {
  name = "{{ attrs.role_name }}"
{% if attrs.path and attrs.path != "/" %}
  path = "{{ attrs.path }}"
{% endif %}
{% if attrs.description %}
  description = "{{ attrs.description }}"
{% endif %}

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Action = "sts:AssumeRole"
      Effect = "Allow"
      Principal = { Service = "ec2.amazonaws.com" }
    }]
  })
{% if attrs.tags %}

  tags = {
{% for key, value in attrs.tags.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}
