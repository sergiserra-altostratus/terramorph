resource "google_composer_environment" "{{ resource.terraform_resource_name }}" {
  project = "{{ resource.project }}"
  name    = "{{ resource.name }}"
  region  = "{{ attrs.region }}"

  config {
    software_config {
      image_version = "{{ attrs.image_version }}"
    }

    node_config {
      machine_type = "{{ attrs.machine_type }}"
    }
  }

{% if attrs.labels %}
  labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}
