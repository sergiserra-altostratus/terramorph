resource "google_cloud_scheduler_job" "{{ resource.terraform_resource_name }}" {
  project  = "{{ resource.project }}"
  name     = "{{ resource.name }}"
  region   = "{{ resource.location }}"
  schedule = "{{ attrs.schedule }}"
{% if attrs.time_zone %}
  time_zone = "{{ attrs.time_zone }}"
{% endif %}
{% if attrs.description %}
  description = "{{ attrs.description }}"
{% endif %}
{% if attrs.attempt_deadline %}
  attempt_deadline = "{{ attrs.attempt_deadline }}"
{% endif %}

{% if attrs.http_target %}
  http_target {
    uri         = "{{ attrs.http_target.get('uri', '') }}"
    http_method = "{{ attrs.http_target.get('httpMethod', 'POST') }}"
  }
{% endif %}

{% if attrs.pubsub_target %}
  pubsub_target {
    topic_name = "{{ attrs.pubsub_target.get('topicName', '') }}"
  }
{% endif %}
}
