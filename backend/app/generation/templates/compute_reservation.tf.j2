resource "google_compute_reservation" "{{ resource.terraform_resource_name }}" {
  project = "{{ resource.project }}"
  name    = "{{ resource.name }}"
  zone    = "{{ attrs.zone }}"
{% if attrs.description %}
  description = "{{ attrs.description }}"
{% endif %}

  specific_reservation {
    count = 1
    instance_properties {
      machine_type = "n1-standard-1"
    }
  }
}
