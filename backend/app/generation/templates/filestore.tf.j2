resource "google_filestore_instance" "{{ resource.terraform_resource_name }}" {
  project  = "{{ resource.project }}"
  name     = "{{ resource.name }}"
  location = "{{ attrs.zone }}"
  tier     = "{{ attrs.tier }}"

  file_shares {
    name       = "{{ attrs.file_share_name }}"
    capacity_gb = {{ attrs.capacity_gb }}
  }

  networks {
    network = "{{ attrs.network }}"
    modes   = ["MODE_IPV4"]
  }
{% if attrs.labels %}
  labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}
