resource "google_compute_instance_template" "{{ resource.terraform_resource_name }}" {
  project      = "{{ resource.project }}"
  name         = "{{ resource.name }}"
  machine_type = "{{ attrs.machine_type }}"
{% if attrs.description %}
  description  = "{{ attrs.description }}"
{% endif %}

  disk {
    auto_delete  = true
    boot         = true
    source_image = ""
  }

  network_interface {
    network = "default"
  }

{% if attrs.labels %}
  labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}
