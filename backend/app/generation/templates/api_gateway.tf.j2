resource "google_api_gateway_api" "{{ resource.terraform_resource_name }}" {
  project  = "{{ resource.project }}"
  api_id   = "{{ attrs.api_id }}"
{% if attrs.display_name %}
  display_name = "{{ attrs.display_name }}"
{% endif %}
{% if attrs.labels %}
  labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}
