module "{{ resource.terraform_resource_name }}" {
  source  = "GoogleCloudPlatform/sql-db/google//modules/{{ 'postgresql' if 'POSTGRES' in attrs.database_version else 'mysql' }}"
  version = "~> 20.0"

  project_id       = "{{ resource.project }}"
  name             = "{{ resource.name }}"
  database_version = "{{ attrs.database_version }}"
  region           = "{{ attrs.region }}"
  zone             = "{{ attrs.region }}-a"
  tier             = "{{ attrs.tier }}"

  availability_type = "{{ attrs.availability_type }}"
  disk_size         = {{ attrs.disk_size }}
  disk_type         = "{{ attrs.disk_type }}"

  deletion_protection = false

{% if attrs.backup_enabled %}
  backup_configuration = {
    enabled = true
  }
{% endif %}

  ip_configuration = {
    ipv4_enabled = {{ attrs.ipv4_enabled | lower }}
  }

{% if attrs.labels %}
  user_labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}
