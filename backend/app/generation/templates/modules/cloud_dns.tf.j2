module "{{ resource.terraform_resource_name }}" {
  source  = "terraform-google-modules/cloud-dns/google"
  version = "~> 5.0"

  project_id = "{{ resource.project }}"
  name       = "{{ resource.name }}"
  domain     = "{{ attrs.dns_name }}"
  type       = "{{ attrs.visibility }}"

{% if attrs.description %}
  description = "{{ attrs.description }}"
{% endif %}

{% if attrs.labels %}
  labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}

  recordsets = []
}
