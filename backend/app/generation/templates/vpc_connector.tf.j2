resource "google_vpc_access_connector" "{{ resource.terraform_resource_name }}" {
  project        = "{{ resource.project }}"
  name           = "{{ resource.name }}"
  region         = "{{ attrs.region }}"
  network        = "{{ attrs.network }}"
  ip_cidr_range  = "{{ attrs.ip_cidr_range }}"
  min_throughput = {{ attrs.min_throughput }}
  max_throughput = {{ attrs.max_throughput }}
  machine_type   = "{{ attrs.machine_type }}"
}
