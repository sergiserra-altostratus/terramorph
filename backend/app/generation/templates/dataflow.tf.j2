resource "google_dataflow_job" "{{ resource.terraform_resource_name }}" {
  project           = "{{ resource.project }}"
  name              = "{{ resource.name }}"
  region            = "{{ attrs.region }}"
  template_gcs_path = "{{ attrs.template_gcs_path }}"
  temp_gcs_location = "{{ attrs.temp_gcs_location }}"
}
