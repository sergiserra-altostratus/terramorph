resource "google_compute_ha_vpn_gateway" "{{ resource.terraform_resource_name }}" {
  project = "{{ resource.project }}"
  name    = "{{ resource.name }}"
  region  = "{{ attrs.region }}"
  network = "{{ attrs.network }}"
{% if attrs.stack_type != "IPV4_ONLY" %}
  stack_type = "{{ attrs.stack_type }}"
{% endif %}
}
