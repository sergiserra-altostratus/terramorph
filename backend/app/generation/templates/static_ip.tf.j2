resource "google_compute_address" "{{ resource.terraform_resource_name }}" {
  project      = "{{ resource.project }}"
  name         = "{{ resource.name }}"
{% if attrs.region %}
  region       = "{{ attrs.region }}"
{% endif %}
  address_type = "{{ attrs.address_type }}"
{% if attrs.purpose %}
  purpose      = "{{ attrs.purpose }}"
{% endif %}
{% if attrs.description %}
  description  = "{{ attrs.description }}"
{% endif %}
}
