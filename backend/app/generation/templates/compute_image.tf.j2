resource "google_compute_image" "{{ resource.terraform_resource_name }}" {
  project      = "{{ resource.project }}"
  name         = "{{ resource.name }}"
{% if attrs.source_disk %}
  source_disk  = "{{ attrs.source_disk }}"
{% endif %}
{% if attrs.family %}
  family       = "{{ attrs.family }}"
{% endif %}
  disk_size_gb = {{ attrs.disk_size_gb }}
{% if attrs.labels %}
  labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}
