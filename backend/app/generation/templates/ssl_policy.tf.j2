resource "google_compute_ssl_policy" "{{ resource.terraform_resource_name }}" {
  project         = "{{ resource.project }}"
  name            = "{{ resource.name }}"
  min_tls_version = "{{ attrs.min_tls_version }}"
  profile         = "{{ attrs.profile }}"
{% if attrs.description %}
  description     = "{{ attrs.description }}"
{% endif %}
}
