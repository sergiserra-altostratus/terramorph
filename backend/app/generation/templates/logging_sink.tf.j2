resource "google_logging_project_sink" "{{ resource.terraform_resource_name }}" {
  project     = "{{ resource.project }}"
  name        = "{{ resource.name }}"
  destination = "{{ attrs.destination }}"
{% if attrs.filter %}
  filter      = "{{ attrs.filter }}"
{% endif %}
{% if attrs.description %}
  description = "{{ attrs.description }}"
{% endif %}
  disabled    = {{ attrs.disabled | lower }}

  unique_writer_identity = true
}
