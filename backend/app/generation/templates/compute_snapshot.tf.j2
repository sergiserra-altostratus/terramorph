resource "google_compute_snapshot" "{{ resource.terraform_resource_name }}" {
  project     = "{{ resource.project }}"
  name        = "{{ resource.name }}"
  source_disk = "{{ attrs.source_disk }}"
{% if attrs.labels %}
  labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}
