resource "google_bigtable_instance" "{{ resource.terraform_resource_name }}" {
  project       = "{{ resource.project }}"
  name          = "{{ resource.name }}"
  display_name  = "{{ attrs.display_name }}"
  instance_type = "{{ attrs.instance_type }}"

{% if attrs.labels %}
  labels = {
{% for key, value in attrs.labels.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}

  cluster {
    cluster_id = "{{ resource.name }}-cluster"
    num_nodes  = 1
  }
}
