# Terramorph Configuration
# ========================

# GCP Credentials - path to your ADC JSON file
GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/application_default_credentials.json

# Ports
BACKEND_PORT=8001
FRONTEND_PORT=3000

# Environment (development / production)
TERRAMORPH_ENV=development
TERRAMORPH_LOG_LEVEL=debug

# Docker build target (development / production)
DOCKER_TARGET=development

# Install gcloud CLI for Bulk Export mode (set to false for smaller image ~500MB less)
INSTALL_GCLOUD=true
